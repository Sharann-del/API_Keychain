# ---------------------------------------------------------------------------
# Frontend env (Next.js). Copy to `.env.local` for local dev, and set the same
# NEXT_PUBLIC_* values in the Vercel project's Environment Variables.
# ---------------------------------------------------------------------------

# Supabase project credentials (Project Settings -> Data API / Connect dialog).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Legacy anon key name (still supported):
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Or use the Connect-dialog publishable key name:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Base URL of the FastAPI backend (no trailing slash).
#
#   Local dev:  http://localhost:8000
#   Production: https://api.apikeychain.dev
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Server-only Supabase env (Vercel / Next.js — never commit real secrets).
# Copy values from Supabase Connect dialog. Falls back to NEXT_PUBLIC_* where noted.
# ---------------------------------------------------------------------------
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SECRET_KEY=sb_secret_...
# SUPABASE_JWKS_URL=https://YOUR-PROJECT.supabase.co/auth/v1/.well-known/jwks.json

# ---------------------------------------------------------------------------
# Backend-only env (FastAPI on Render). NOT used by the Next.js dashboard.
# ---------------------------------------------------------------------------
# SUPABASE_JWT_SECRET=...   # Project Settings -> API -> JWT secret (HS256, legacy)
# MASTER_SECRET=...         # used to encrypt provider keys at rest
# SUPABASE_URL=...          # same project URL as NEXT_PUBLIC_SUPABASE_URL
# CORS_ORIGINS=http://localhost:3000,https://www.apikeychain.dev,https://apikeychain.dev
#
# Persistent app data (required on Render — default SQLite is wiped on redeploy):
# DATABASE_URL=postgresql+psycopg2://postgres.[ref]:[password]@....pooler.supabase.com:6543/postgres
